generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Player {
  id             String   @id @default(cuid())
  telegramUserId String   @unique
  name           String
  position       String
  country        String
  age            Int      @default(14)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
