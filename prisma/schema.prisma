generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PlayerPosition {
  GOALKEEPER
  DEFENDER
  MIDFIELDER
  FORWARD
}

enum DominantFoot {
  RIGHT
  LEFT
}

enum CareerStatus {
  YOUTH
  PROFESSIONAL
}

enum AttributeKey {
  REFLEXES
  HANDLING
  KICKING
  POSITIONING
  PASSING
  SHOOTING
  DRIBBLING
  SPEED
  MARKING
}

enum TrainingFocus {
  REFLEXES
  HANDLING
  KICKING
  POSITIONING
  PASSING
  SHOOTING
  DRIBBLING
  SPEED
  MARKING
}

enum WalletTransactionType {
  INITIAL_GRANT
  TRAINING_COST
  TRYOUT_COST
}

enum TryoutStatus {
  FAILED
  APPROVED
}

enum HistoryEntryType {
  PLAYER_CREATED
  TRAINING_COMPLETED
  TRYOUT_FAILED
  TRYOUT_APPROVED
  PROFESSIONAL_CONTRACT_STARTED
}

enum PlayerCreationStep {
  NAME
  NATIONALITY
  POSITION
  DOMINANT_FOOT
  HEIGHT_CM
  WEIGHT_KG
  SKIN_TONE
  HAIR_STYLE
  CONFIRMATION
}

enum MatchStatus {
  PENDING
  IN_PROGRESS
  FINISHED
}

enum MatchHalf {
  FIRST_HALF
  SECOND_HALF
  EXTRA_TIME
  PENALTIES
}

enum MatchTurnState {
  PENDING
  RESOLVED
  TIMED_OUT
}

enum MatchPossessionSide {
  HOME
  AWAY
}

enum MatchRole {
  USER_PLAYER
  GOALKEEPER
  CPU_SUPPORT
}

enum MatchParticipantKind {
  HUMAN
  BOT
}

enum MatchContextType {
  RECEIVED_FREE
  RECEIVED_PRESSED
  BACK_TO_GOAL
  IN_BOX
  DEFENSIVE_DUEL
  GOALKEEPER_SAVE
  PENALTY_KICK
  FREE_KICK
  CORNER_KICK
}

enum MatchActionKey {
  PASS
  DRIBBLE
  SHOOT
  CONTROL
  PROTECT
  TACKLE
  CLEAR
  SAVE
  PUNCH
  CATCH
  RUSH_OUT
  REBOUND
  DISTRIBUTE_HAND
  DISTRIBUTE_FOOT
  AIM_LOW_LEFT
  AIM_LOW_RIGHT
  AIM_HIGH_LEFT
  AIM_HIGH_RIGHT
}

enum MatchEventType {
  TURN_STARTED
  ACTION_RESOLVED
  TIMEOUT
  GOAL
  FOUL
  PENALTY_AWARDED
  CORNER_AWARDED
  GOAL_KICK_AWARDED
  THROW_IN_AWARDED
  YELLOW_CARD
  RED_CARD
  INJURY
  SUSPENSION
  MATCH_FINISHED
}

enum MultiplayerLobbyStatus {
  OPEN
  READY
  CLOSED
}

enum MultiplayerLobbyFillPolicy {
  HUMAN_ONLY
  HUMAN_PRIORITY_WITH_BOT_FALLBACK
}

enum MultiplayerParticipantKind {
  HUMAN
  BOT
}

model User {
  id                  String                        @id @default(cuid())
  telegramId          String                        @unique
  createdAt           DateTime                      @default(now())
  updatedAt           DateTime                      @updatedAt
  generations         PlayerGeneration[]
  hostedLobbies       MultiplayerLobby[]            @relation("HostedMultiplayerLobbies")
  lobbyParticipations MultiplayerLobbyParticipant[]
}

model PlayerGeneration {
  id               String   @id @default(cuid())
  userId           String
  generationNumber Int
  inheritedPoints  Int      @default(0)
  isCurrent        Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id])
  player           Player?

  @@unique([userId, generationNumber])
  @@index([userId, isCurrent])
}

model Player {
  id                        String                        @id @default(cuid())
  generationId              String                        @unique
  name                      String
  nationality               String
  position                  PlayerPosition
  dominantFoot              DominantFoot
  age                       Int
  heightCm                  Int
  weightKg                  Int
  skinTone                  String
  hairStyle                 String
  careerStatus              CareerStatus                  @default(YOUTH)
  currentClubId             String?
  createdAt                 DateTime                      @default(now())
  updatedAt                 DateTime                      @updatedAt
  generation                PlayerGeneration              @relation(fields: [generationId], references: [id])
  currentClub               Club?                         @relation(fields: [currentClubId], references: [id])
  attributes                PlayerAttribute[]
  wallet                    Wallet?
  trainingSessions          TrainingSession[]
  tryoutAttempts            TryoutAttempt[]
  clubMemberships           ClubMembership[]
  historyEntries            PlayerHistoryEntry[]
  matchLineups              MatchLineup[]
  matches                   Match[]
  disciplinaryEvents        MatchDisciplinaryEvent[]
  injuries                  InjuryRecord[]
  suspensions               SuspensionRecord[]
  hostedMultiplayerLobbies  MultiplayerLobby[]            @relation("PlayerHostedMultiplayerLobbies")
  multiplayerParticipations MultiplayerLobbyParticipant[]

  @@index([currentClubId])
}

model PlayerAttribute {
  id        String       @id @default(cuid())
  playerId  String
  key       AttributeKey
  value     Int
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  player    Player       @relation(fields: [playerId], references: [id])

  @@unique([playerId, key])
}

model Wallet {
  id           String              @id @default(cuid())
  playerId     String              @unique
  balance      Int
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  player       Player              @relation(fields: [playerId], references: [id])
  transactions WalletTransaction[]
}

model WalletTransaction {
  id          String                @id @default(cuid())
  walletId    String
  type        WalletTransactionType
  amount      Int
  description String
  createdAt   DateTime              @default(now())
  wallet      Wallet                @relation(fields: [walletId], references: [id])

  @@index([walletId, createdAt])
}

model TrainingSession {
  id            String        @id @default(cuid())
  playerId      String
  weekNumber    Int
  focus         TrainingFocus
  cost          Int
  attributeGain Int
  createdAt     DateTime      @default(now())
  player        Player        @relation(fields: [playerId], references: [id])

  @@unique([playerId, weekNumber])
  @@index([playerId, createdAt])
}

model TryoutAttempt {
  id            String       @id @default(cuid())
  playerId      String
  cost          Int
  weekNumber    Int
  score         Int
  requiredScore Int
  status        TryoutStatus
  clubId        String?
  createdAt     DateTime     @default(now())
  player        Player       @relation(fields: [playerId], references: [id])
  club          Club?        @relation(fields: [clubId], references: [id])

  @@index([playerId, createdAt])
  @@index([clubId])
}

model Club {
  id          String           @id @default(cuid())
  name        String           @unique
  country     String
  city        String
  division    String
  reputation  Int
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  players     Player[]
  memberships ClubMembership[]
  tryouts     TryoutAttempt[]
  homeMatches Match[]          @relation("HomeMatches")
  awayMatches Match[]          @relation("AwayMatches")
}

model ClubMembership {
  id       String   @id @default(cuid())
  playerId String
  clubId   String
  joinedAt DateTime @default(now())
  role     String
  isActive Boolean  @default(true)
  player   Player   @relation(fields: [playerId], references: [id])
  club     Club     @relation(fields: [clubId], references: [id])

  @@index([playerId, isActive])
  @@index([clubId, isActive])
}

model PlayerHistoryEntry {
  id          String           @id @default(cuid())
  playerId    String
  type        HistoryEntryType
  description String
  metadata    Json?
  createdAt   DateTime         @default(now())
  player      Player           @relation(fields: [playerId], references: [id])

  @@index([playerId, createdAt])
}

model PlayerCreationConversation {
  telegramId String             @id
  step       PlayerCreationStep
  draft      Json
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
}

model Match {
  id                 String                   @id @default(cuid())
  playerId           String
  homeClubId         String
  awayClubId         String
  homeScore          Int                      @default(0)
  awayScore          Int                      @default(0)
  currentMinute      Int                      @default(0)
  currentHalf        MatchHalf                @default(FIRST_HALF)
  status             MatchStatus              @default(PENDING)
  possessionSide     MatchPossessionSide      @default(HOME)
  stoppageMinutes    Int                      @default(0)
  userEnergy         Int                      @default(100)
  yellowCards        Int                      @default(0)
  redCards           Int                      @default(0)
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  player             Player                   @relation(fields: [playerId], references: [id])
  homeClub           Club                     @relation("HomeMatches", fields: [homeClubId], references: [id])
  awayClub           Club                     @relation("AwayMatches", fields: [awayClubId], references: [id])
  lineups            MatchLineup[]
  turns              MatchTurn[]
  events             MatchEvent[]
  disciplinary       MatchDisciplinaryEvent[]
  injuries           InjuryRecord[]
  suspensions        SuspensionRecord[]
  multiplayerLobbies MultiplayerLobby[]

  @@index([playerId, status, createdAt])
}

model MatchLineup {
  id               String               @id @default(cuid())
  matchId          String
  playerId         String?
  side             MatchPossessionSide
  role             MatchRole
  participantKind  MatchParticipantKind @default(BOT)
  displayName      String
  shirtNumber      Int?
  isUserControlled Boolean              @default(false)
  createdAt        DateTime             @default(now())
  match            Match                @relation(fields: [matchId], references: [id])
  player           Player?              @relation(fields: [playerId], references: [id])

  @@index([matchId, side])
}

model MatchTurn {
  id                  String              @id @default(cuid())
  matchId             String
  sequence            Int
  minute              Int
  half                MatchHalf
  possessionSide      MatchPossessionSide
  contextType         MatchContextType
  contextText         String
  availableActions    MatchActionKey[]
  chosenAction        MatchActionKey?
  deadlineAt          DateTime
  resolvedAt          DateTime?
  resolutionText      String?
  state               MatchTurnState      @default(PENDING)
  previousOutcome     String?
  isGoalkeeperContext Boolean             @default(false)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  match               Match               @relation(fields: [matchId], references: [id])
  events              MatchEvent[]

  @@unique([matchId, sequence])
  @@index([matchId, state, sequence])
}

model MatchEvent {
  id          String         @id @default(cuid())
  matchId     String
  turnId      String?
  type        MatchEventType
  minute      Int
  description String
  metadata    Json?
  createdAt   DateTime       @default(now())
  match       Match          @relation(fields: [matchId], references: [id])
  turn        MatchTurn?     @relation(fields: [turnId], references: [id])

  @@index([matchId, createdAt])
}

model MatchDisciplinaryEvent {
  id                String         @id @default(cuid())
  matchId           String
  playerId          String
  type              MatchEventType
  minute            Int
  description       String
  suspensionMatches Int            @default(0)
  createdAt         DateTime       @default(now())
  match             Match          @relation(fields: [matchId], references: [id])
  player            Player         @relation(fields: [playerId], references: [id])

  @@index([playerId, createdAt])
  @@index([matchId, createdAt])
}

model InjuryRecord {
  id               String   @id @default(cuid())
  playerId         String
  matchId          String?
  description      String
  severity         Int
  matchesRemaining Int
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  player           Player   @relation(fields: [playerId], references: [id])
  match            Match?   @relation(fields: [matchId], references: [id])

  @@index([playerId, isActive])
}

model SuspensionRecord {
  id               String         @id @default(cuid())
  playerId         String
  matchId          String?
  reason           String
  sourceEventType  MatchEventType
  matchesRemaining Int
  isActive         Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  player           Player         @relation(fields: [playerId], references: [id])
  match            Match?         @relation(fields: [matchId], references: [id])

  @@index([playerId, isActive])
}

model MultiplayerLobby {
  id                       String                        @id @default(cuid())
  lobbyCode                String                        @unique
  status                   MultiplayerLobbyStatus        @default(OPEN)
  fillPolicy               MultiplayerLobbyFillPolicy    @default(HUMAN_PRIORITY_WITH_BOT_FALLBACK)
  maxParticipants          Int                           @default(2)
  botFallbackEligibleSlots Int                           @default(0)
  hostUserId               String
  createdByPlayerId        String
  readyForMatchAt          DateTime?
  linkedMatchId            String?
  createdAt                DateTime                      @default(now())
  updatedAt                DateTime                      @updatedAt
  hostUser                 User                          @relation("HostedMultiplayerLobbies", fields: [hostUserId], references: [id])
  createdByPlayer          Player                        @relation("PlayerHostedMultiplayerLobbies", fields: [createdByPlayerId], references: [id])
  linkedMatch              Match?                        @relation(fields: [linkedMatchId], references: [id])
  participants             MultiplayerLobbyParticipant[]

  @@index([status, createdAt])
}

model MultiplayerLobbyParticipant {
  id         String                     @id @default(cuid())
  lobbyId    String
  userId     String
  playerId   String
  slotNumber Int
  kind       MultiplayerParticipantKind @default(HUMAN)
  isHost     Boolean                    @default(false)
  joinedAt   DateTime                   @default(now())
  lobby      MultiplayerLobby           @relation(fields: [lobbyId], references: [id])
  user       User                       @relation(fields: [userId], references: [id])
  player     Player                     @relation(fields: [playerId], references: [id])

  @@unique([lobbyId, userId])
  @@unique([lobbyId, slotNumber])
  @@index([userId, joinedAt])
  @@index([playerId, joinedAt])
}
