{
  "name": "telesoccer",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "dev": "npm run dev -w @telesoccer/api",
    "build": "npm run build -w @telesoccer/api",
    "start": "npm run start -w @telesoccer/api",
    "typecheck": "npm run typecheck -w @telesoccer/api && npm run typecheck -w @telesoccer/web"
  }
}
