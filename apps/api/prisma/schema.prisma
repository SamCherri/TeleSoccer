generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Match {
  id          String   @id @default(cuid())
  status      String
  minute      Int
  homeScore   Int      @default(0)
  awayScore   Int      @default(0)
  sceneText   String
  possession  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
