    "prisma:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@prisma/client": "^6.7.0",
    "fastify": "^5.6.1",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "prisma": "^6.7.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
